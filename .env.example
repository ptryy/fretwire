# Payment integration mode: "mock" (offline, simulated) or "http" (real gateway).
PAYMENTS_MODE=http

# NextPayments gateway (crypto-payment-be). Required only when PAYMENTS_MODE=http.
NEXTPAYMENTS_API_URL=https://api.omnipayx.io
NEXTPAYMENTS_PUBLIC_KEY=
NEXTPAYMENTS_PRIVATE_KEY=
NEXTPAYMENTS_IPN_SECRET=dev-ipn-secret

# Public origin of THIS shop (used to build the IPN callback URL).
APP_URL=http://localhost:3000

# Unlocks /dev/config on a deployed build (the runtime gateway-config editor,
# which can repoint the gateway and inject keys without a rebuild). Unset -> the
# route 404s, as if the feature didn't exist; local dev needs no token. It is the
# whole security boundary and unlock attempts are not rate-limited: use a random
# 32+ char value, never a word. Keep it in env/secrets only — never commit it.
DEV_CONFIG_TOKEN=

# Optional: override the SQLite file path.
# DB_PATH=shop.db
